<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <key>Label</key>
        <string>com.user.updateEnv</string>
        <key>ProgramArguments</key>
        <array>
            <string>/bin/zsh</string>
            <string>-c</string>
            <string>/usr/bin/make -f $DOTPATH/Makefile upgrade</string>
        </array>
        <key>StartCalendarInterval</key>
        <dict>
            <key>Day</key>
            <integer>1</integer>
            <key>Hour</key>
            <integer>21</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
        <key>StandardErrorPath</key>
        <string>/tmp/updateEnv.err</string>
        <key>StandardOutPath</key>
        <string>/tmp/updateEnv.out</string>
    </dict>
</plist>
